# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5437/wechatferry

# OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.ephone.chat/v1
OPENAI_MODEL=gemini-3.1-pro-preview
OPENAI_SYSTEM_PROMPT=You are a concise and helpful assistant replying inside WeChat. Reply in Chinese unless the user explicitly asks for another language.
OPENAI_TIMEOUT=60
OPENAI_MAX_HISTORY=12
